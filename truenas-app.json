{
  "app_name": "360-viewer",
  "version": "1.1.0",
  "description": "Visualizador web para videos 360° con sistema de bibliotecas y navegación por carpetas",
  "container": {
    "image": "360-viewer:latest",
    "port": 8080,
    "host_port": 8080
  },
  "storage": [
    {
      "host_path": "/mnt/pool/videos-360",
      "mount_path": "/videos",
      "read_only": true,
      "description": "Directorio con videos 360°"
    },
    {
      "host_path": "/mnt/pool/app-data/360-viewer",
      "mount_path": "/app/data",
      "read_only": false,
      "description": "Datos de bibliotecas (persistencia)"
    }
  ],
  "environment": {
    "VIDEOS_PATH": "/videos",
    "LIBRARIES_FILE": "/app/data/.libraries.json"
  }
}
